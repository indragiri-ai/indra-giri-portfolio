# --- GitHub Pages ---
# Set to /your-repo-name for project pages (e.g. /indra-giri-portfolio).
# Leave empty for user/org pages (username.github.io).
NEXT_PUBLIC_BASE_PATH=/indra-giri-portfolio

# --- Formspree (contact form) ---
# Sign up free at https://formspree.io, create a form, and paste the ID here.
# The form ID is the last segment of your endpoint: formspree.io/f/<FORM_ID>
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id
